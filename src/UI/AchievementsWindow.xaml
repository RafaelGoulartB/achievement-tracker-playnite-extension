<Window x:Class="AchievementTracker.UI.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Achievements" Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="GameTitleText" Text="Game Title" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Grid.Row="0" Foreground="White"/>
        
        <ListBox x:Name="AchievementsList" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                 HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="0,2" Background="#252525" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Icon -->
                            <Border Width="40" Height="40" Background="#333" CornerRadius="4" VerticalAlignment="Center" Grid.Column="0">
                                <Image Source="{Binding IconUrl}" Stretch="UniformToFill" />
                            </Border>
                            
                            <!-- Info -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="White"/>
                                <TextBlock Text="{Binding DisplayDescription}" FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                
                                <!-- Status -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding IsUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="✓ Unlocked" FontSize="11" Foreground="#4CAF50" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding UnlockTime, StringFormat='  ({0:g})'}" FontSize="11" Foreground="#888888"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Rarity -->
                            <TextBlock Text="{Binding Rarity, StringFormat={}{0:0.#}%}" Grid.Column="2" 
                                       VerticalAlignment="Top" HorizontalAlignment="Right"
                                       Foreground="#66FFFFFF" FontSize="11" Margin="10,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Empty State -->
        <TextBlock x:Name="EmptyStateText" Text="No achievements found locally." HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Foreground="#888" Visibility="Collapsed"/>

        <!-- Debug Footer -->
        <Border Grid.Row="2" Background="#111" Padding="10,5" BorderBrush="#333" BorderThickness="0,1,0,0" Margin="-15,10,-15,-15">
            <TextBlock x:Name="DebugInfoText" Foreground="#888" FontSize="10" Text="Ready"/>
        </Border>
    </Grid>
</Window>
