<Window x:Class="AchievementTracker.UI.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Achievement Tracker – Debug Info"
        Width="900" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4"
        FontFamily="Consolas" FontSize="12">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#A6E3A1"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🎮 " FontSize="20"/>
            <TextBlock x:Name="GameTitle" FontSize="18" FontWeight="Bold" Foreground="#89B4FA" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- AppId detection -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="🔍 Steam AppId Detection"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Detected AppId:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AppIdText" FontWeight="Bold" Foreground="#F38BA8"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Source:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AppIdSourceText" Foreground="#FAB387"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Steam request -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="🌐 Steam Web Request"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="URL:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SteamUrlText" TextWrapping="Wrap" Foreground="#89DCEB"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Result:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SteamResultText" FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Achievements:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SteamCountText"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Error:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SteamErrorText" Foreground="#F38BA8" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Steam Metadata JSON -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="📄 Steam Achievement Metadata (Downloaded JSON)"/>
                        <TextBox x:Name="SteamMetadataBox" Height="150" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Hydra Metadata JSON -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="🌐 Hydra API Response (Downloaded JSON)"/>
                        <TextBox x:Name="HydraMetadataBox" Height="150" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Local files found -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="📁 Local Files Found (unlock status source)"/>
                        <TextBox x:Name="LocalFilesFoundBox" Height="110"/>
                    </StackPanel>
                </Border>

                <!-- Local files checked but missing -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="❌ Checked Paths (not found on disk)"/>
                        <TextBox x:Name="LocalFilesCheckedBox" Height="80"/>
                    </StackPanel>
                </Border>

                <!-- Audio Settings Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="🔊 Notification Audio Settings"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Enable/Disable Toggle -->
                            <CheckBox Grid.Row="0" Grid.Column="0" x:Name="SoundEnabledCheckBox"
                                      Content="Enable Notification Sounds"
                                      IsChecked="True"
                                      ToolTip="Toggle notification sound playback"
                                      IsEnabled="False"
                                      Click="OnSoundEnabledChanged"/>

                            <!-- Sound Dropdown -->
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SoundFileComboBox"
                                       DisplayMemberPath="Name"
                                       VerticalAlignment="Top" Margin="10,4,0,0"
                                       SelectionChanged="OnSoundSelectedChanged">
                                <ComboBox.Resources>
                                    <Style TargetType="Button">
                                        <Setter Property="ClickMode" Value="Press"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <!-- Preview Button -->
                            <Button Grid.Row="0" Grid.Column="1" x:Name="PreviewSoundBtn"
                                     Content="▶ Preview"
                                     Width="80" Height="25"
                                     ToolTip="Play selected sound preview"
                                     Click="OnPreviewSound"/>
                        </Grid>
                        <TextBlock x:Name="AvailableSoundsText" Foreground="#89B4FA" FontSize="11"
                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Sound Directories -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="📁 Sound File Locations"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Configured Directories:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SoundDirectoriesText" TextWrapping="Wrap" Foreground="#A6E3A1"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Discovered Files:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DiscoveredFilesText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- NEW: Local Unlocks Detail -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="🔑 Local Achievement IDs/Names Found"/>
                        <TextBox x:Name="LocalUnlocksBox" Height="100"/>
                    </StackPanel>
                </Border>

                <!-- NEW: Match Detail -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="🤝 Match History (Steam achievement --&gt; Local Match)"/>
                        <TextBox x:Name="MatchHistoryBox" Height="180" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Summary -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Label Content="📊 Final Result"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ModeText" FontWeight="Bold" Foreground="#A6E3A1"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Total achievements:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalText"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Locally unlocked:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UnlockedText"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Scan time:" Foreground="#6C7086"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ScanTimeText"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RefreshBtn" Content="↺ Re-scan" Click="OnRefresh" Margin="0,0,8,0"/>
            <Button x:Name="CopyBtn"    Content="📋 Copy All" Click="OnCopy"/>
            <Button x:Name="LoadSoundsBtn" Content="🔄 Load Sounds" Click="OnLoadSoundFiles" Margin="0,0,8,0"/>
        </StackPanel>
    </Grid>
</Window>
