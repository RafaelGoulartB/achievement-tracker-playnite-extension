<Window x:Class="AchievementTracker.UI.DebugTrackingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Achievement Tracker"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4"
        FontFamily="Consolas" FontSize="12"
        Loaded="OnWindowLoaded" Closed="OnWindowClosed">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tracking Status Header (US-002) -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="GameNameText" FontSize="16" FontWeight="Bold" Foreground="#89B4FA" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tracking:" Foreground="#6C7086"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TrackingStatusText" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="AppId:" Foreground="#6C7086"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AppIdText"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Interval:" Foreground="#6C7086"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="IntervalText"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Scan:" Foreground="#6C7086"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LastScanText"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Config Display and Edit (US-007 / US-004) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Configuration" FontSize="14" FontWeight="Bold" Foreground="#89B4FA" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled:" Foreground="#6C7086"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ConfigEnabledText"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Polling Interval (s):" Foreground="#6C7086"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="PollingIntervalBox" Width="60" HorizontalAlignment="Left"
                             Background="#1E1E2E" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="4,2"
                             TextAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Notification Timeout (s):" Foreground="#6C7086"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="NotificationTimeoutBox" Width="60" HorizontalAlignment="Left"
                             Background="#1E1E2E" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="4,2"
                             TextAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Notification Sound:" Foreground="#6C7086"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ConfigSoundCheck" Content="" Background="#1E1E2E" Foreground="#CDD6F4"
                              Checked="OnSoundToggleChanged" Unchecked="OnSoundToggleChanged"/>

                    <!-- Volume settings (moved from AchievementTrackerControl) -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Volume:" Foreground="#6C7086" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="50" Width="200"
                                VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"
                                IsSnapToTickEnabled="True" TickFrequency="1" />
                        <TextBlock x:Name="VolumeText" Text="50%" Foreground="#A6E3A1" FontSize="12"
                                   VerticalAlignment="Center" Width="40" Margin="8,0,0,0" />
                        <Button x:Name="PreviewButton" Content="Preview" Background="#89B4FA" Foreground="#1E1E2E"
                                FontSize="11" Padding="8,4" Margin="8,0,0,0" Cursor="Hand"
                                Click="OnPreviewSoundClick" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Tabbed content area (US-003 / US-004) -->
        <TabControl Grid.Row="2" Background="Transparent" BorderBrush="#45475A">
            <!-- Scan Log Tab -->
            <TabItem Header="Scan Log" Foreground="#CDD6F4">
                <Border Style="{StaticResource Card}" BorderThickness="0" Margin="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Background="#1E1E2E" Padding="6">
                            <TextBlock x:Name="LogTextBlock" TextWrapping="NoWrap" FontSize="11"/>
                        </ScrollViewer>
                        <Button Grid.Row="1" Content="Clear Log" Click="OnClearLog" Margin="0,4,0,0" HorizontalAlignment="Left" Padding="8,4"/>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Snapshot Diff Tab -->
            <TabItem Header="Snapshot Diff" Foreground="#CDD6F4">
                <Border Style="{StaticResource Card}" BorderThickness="0" Margin="4">
                    <Grid>
                        <TextBlock x:Name="DiffPlaceholderText" Text="No tracking data available" Foreground="#6C7086" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ListBox x:Name="DiffListBox" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock FontWeight="Bold" Foreground="#CDD6F4">
                                            <Run Text="{Binding AchievementName}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#6C7086" FontSize="11">
                                            <Run Text="Previous: "/>
                                            <Run Text="{Binding PreviousState}" Foreground="{Binding PreviousColor}"/>
                                            <Run Text=" | Current: "/>
                                            <Run Text="{Binding CurrentState}" Foreground="{Binding CurrentColor}"/>
                                            <Run Text=" | Source: "/>
                                            <Run Text="{Binding Source}" Foreground="#FAB387"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Notification Tests & Settings (US-006 / US-009) -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Notification Tests" FontSize="14" FontWeight="Bold" Foreground="#89B4FA" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Sound Enabled:" Foreground="#6C7086"/>
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="TestSoundCheck" Content="Play sound on test notification"
                              Background="#1E1E2E" Foreground="#CDD6F4" Checked="OnSoundToggleChanged" Unchecked="OnSoundToggleChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Rarity Tier:" Foreground="#6C7086"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <ComboBox x:Name="TierComboBox" Width="150" Background="#1E1E2E" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6,3">
                            <ComboBoxItem Content="Gold (≤5%)" Tag="Gold"/>
                            <ComboBoxItem Content="Silver (5–25%)" Tag="Silver"/>
                            <ComboBoxItem Content="Bronze (&gt;25%)" Tag="Bronze" IsSelected="True"/>
                        </ComboBox>
                        <Button x:Name="SendTestTierBtn" Content="Send Test" Click="OnSendTierTest" Margin="10,0,0,0" Padding="16,6"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Action buttons (US-005 / US-006 / US-007) -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="ReloadConfigBtn" Content="Reload Config" Click="OnReloadConfig" Margin="0,0,8,0"/>
            <Button x:Name="SaveConfigBtn" Content="Save Config" Click="OnSaveConfig" Margin="0,0,8,0"/>
            <Button x:Name="StartTrackingBtn" Content="Start Tracking" Click="OnStartTracking" Margin="0,0,8,0"/>
            <Button x:Name="StopTrackingBtn" Content="Stop Tracking" Click="OnStopTracking" Margin="0,0,8,0"/>
            <Button x:Name="TestNotificationBtn" Content="Send Test Notification" Click="OnTestNotification" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
