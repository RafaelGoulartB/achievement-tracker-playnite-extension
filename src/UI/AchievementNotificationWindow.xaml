<Window x:Class="AchievementTracker.UI.AchievementNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="OnMouseDown">
    <Border x:Name="MainBorder"
            CornerRadius="8"
            MinWidth="320"
            MaxWidth="400"
            Padding="16"
            Margin="10"
            Background="#1A1A2E"
            BorderBrush="#CD7F32"
            BorderThickness="1"
            Opacity="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.5" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Achievement Icon -->
            <Border Grid.Column="0"
                    Width="48" Height="48"
                    Background="#333333"
                    CornerRadius="6"
                    VerticalAlignment="Top"
                    Margin="0,4,8,0">
                <Image x:Name="IconImage" Stretch="UniformToFill">
                    <Image.Clip>
                        <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,0,48,48" />
                    </Image.Clip>
                </Image>
            </Border>

            <!-- Text Content -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock x:Name="TrophyIndicator"
                               Text="★ "
                               FontSize="10"
                               Foreground="#FFD700"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,2,0"
                               Visibility="Collapsed" />
                    <TextBlock x:Name="HeaderTextBlock"
                               Text="ACHIEVEMENT UNLOCKED"
                               Foreground="#CD7F32"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="NameTextBlock"
                           Text=""
                           Foreground="#FFFFFF"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="DescriptionTextBlock"
                           Text=""
                           Foreground="#AAAAAA"
                           FontSize="12"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="40" />
                <TextBlock x:Name="RarityTextBlock"
                           Text=""
                           Foreground="#66FFFFFF"
                           FontSize="10"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
